# Copy this file to .env and fill in all required values.
# Never commit .env to version control.

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=change-me-strong-password
INFLUX_TOKEN=change-me-influx-api-token
INFLUX_ORG=mallard
INFLUX_BUCKET=metrics

# ── Mallard server ────────────────────────────────────────────────────────────
# Comma-separated API keys — sent as X-API-Key header by the extension
API_KEYS=change-me-api-key-1,change-me-api-key-2
LOG_LEVEL=INFO
RATE_LIMIT=60/minute

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-password

# ── Caddy TLS ─────────────────────────────────────────────────────────────────
# Leave SERVER_DOMAIN=localhost for a self-signed dev cert.
# Set to your real hostname + ACME_EMAIL for automatic Let's Encrypt.
SERVER_DOMAIN=localhost
ACME_EMAIL=

# ── MQTT (optional) ───────────────────────────────────────────────────────────
# Set MQTT_ENABLED=true to start the embedded MQTT broker inside the server
# container. Extensions connect via wss://your-server/mqtt using a password
# from MQTT_CREDENTIALS (comma-separated, independent of API_KEYS).
MQTT_ENABLED=false
MQTT_PORT=8083
MQTT_CREDENTIALS=change-me-mqtt-password-1,change-me-mqtt-password-2
