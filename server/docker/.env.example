# Copy this file to .env and fill in all required values.
# Never commit .env to version control.

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=change-me-strong-password
INFLUX_TOKEN=change-me-influx-api-token
INFLUX_ORG=mallard
INFLUX_BUCKET=metrics

# ── Mallard server ────────────────────────────────────────────────────────────
# Credentials use "label:secret" format — the label becomes the InfluxDB source tag.
# Bare values (no colon) are accepted but get source tag "unknown".
API_KEYS=team-alpha:change-me-api-key-1,team-beta:change-me-api-key-2
LOG_LEVEL=INFO
RATE_LIMIT=60/minute

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-password

# ── Caddy TLS ─────────────────────────────────────────────────────────────────
# Leave SERVER_DOMAIN=localhost for a self-signed dev cert.
# Set to your real hostname + ACME_EMAIL for automatic Let's Encrypt.
SERVER_DOMAIN=localhost
ACME_EMAIL=

# ── MQTT (optional) ───────────────────────────────────────────────────────────
# Set MQTT_ENABLED=true to start the embedded MQTT broker inside the server
# container. Extensions connect via wss://your-server/mqtt using a password
# from MQTT_CREDENTIALS (comma-separated, independent of API_KEYS).
MQTT_ENABLED=false
MQTT_PORT=8083
# MQTT credentials are independent of API_KEYS — label:password format.
MQTT_CREDENTIALS=alice:change-me-mqtt-password-1,ci-pipeline:change-me-mqtt-password-2

# ── Secret management (optional) ──────────────────────────────────────────────
# Uncomment ONE block to pull live credentials from a self-hosted secret manager.
# When active, API_KEYS / MQTT_CREDENTIALS above are ignored.

# --- Infisical ---
# SECRET_MANAGER_TYPE=infisical
# SECRET_MANAGER_URL=http://localhost:8888
# SECRET_MANAGER_TOKEN=your-infisical-machine-token
# INFISICAL_PROJECT_ID=your-project-id
# INFISICAL_ENV_SLUG=prod
# INFISICAL_DB_PASSWORD=change-me-infisical-db-password
# INFISICAL_AUTH_SECRET=change-me-32-char-auth-secret
# INFISICAL_ENCRYPTION_KEY=change-me-32-char-encryption-key
# INFISICAL_MACHINE_TOKEN=

# --- OpenBao ---
# SECRET_MANAGER_TYPE=openbao
# SECRET_MANAGER_URL=http://localhost:8200
# SECRET_MANAGER_TOKEN=your-openbao-token
# OPENBAO_SECRET_PATH=secret/data/mallard/server
# OPENBAO_NAMESPACE=
# OPENBAO_DEV_ROOT_TOKEN=dev-root-token
