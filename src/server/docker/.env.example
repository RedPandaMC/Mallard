# Copy this file to .env and fill in all required values.
# Never commit .env to version control.
#
# A secret manager is required — there is no supported static-credentials-only
# deployment. Pick Infisical or OpenBao, fill in *only* that block below, and
# run compose with the matching overlay:
#   docker compose -f docker-compose.yml -f docker-compose.openbao.yml up -d
#   docker compose -f docker-compose.yml -f docker-compose.infisical.yml up -d
# See docs/guide/secret-management.md for a comparison of the two.

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=change-me-strong-password
INFLUX_TOKEN=change-me-influx-api-token
INFLUX_ORG=mallard
INFLUX_BUCKET=metrics

# ── Mallard server ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
RATE_LIMIT=60/minute

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-password

# ── Caddy TLS ─────────────────────────────────────────────────────────────────
# Leave SERVER_DOMAIN=localhost for a self-signed dev cert.
# Set to your real hostname + ACME_EMAIL for automatic Let's Encrypt.
SERVER_DOMAIN=localhost
ACME_EMAIL=

# ── MQTT (optional) ───────────────────────────────────────────────────────────
# Set MQTT_ENABLED=true to start the embedded MQTT broker inside the server
# container. Extensions connect via wss://your-server/mqtt.
MQTT_ENABLED=false
MQTT_PORT=8083

# ── Secret manager: OpenBao ────────────────────────────────────────────────────
# Fill this in only if running with docker-compose.openbao.yml.
# API_KEYS/MQTT_PASSWORD/CERT_LABELS here are the *initial* values openbao-init
# seeds into OpenBao's KV store on first boot. Rotate credentials afterward
# through OpenBao itself, not by editing this file and re-running compose.
#   API_KEYS      "label:secret" pairs, comma-separated — the label becomes the
#                 InfluxDB source tag (Bearer tokens verify against this too)
#   MQTT_PASSWORD single shared broker password; all MQTT ingest is source='mqtt'
#   CERT_LABELS   "label:cn" pairs mapping an mTLS client-cert CN to a source
#                 label; unmapped CNs fall back to the CN itself
#   WEBHOOK_HMAC_SECRETS
#                 comma-separated HMAC signing secrets for
#                 X-Mallard-Signature-256 verification; empty disables signing.
#                 List old+new during rotation.
OPENBAO_DEV_ROOT_TOKEN=change-me-dev-root-token
API_KEYS=team-alpha:change-me-api-key-1,team-beta:change-me-api-key-2
MQTT_PASSWORD=change-me-mqtt-broker-password
CERT_LABELS=
WEBHOOK_HMAC_SECRETS=

# ── Secret manager: Infisical ──────────────────────────────────────────────────
# Fill this in only if running with docker-compose.infisical.yml — comment out
# the OpenBao block above instead of setting both.
# After first boot, log into Infisical at http://localhost:8888, create a
# project, then create the API_KEYS / MQTT_PASSWORD / CERT_LABELS secrets there
# directly (formats above). There is no .env-based seed step for Infisical
# the way there is for OpenBao.
# INFISICAL_PROJECT_ID=your-project-id
# INFISICAL_MACHINE_TOKEN=your-infisical-machine-token
# INFISICAL_DB_PASSWORD=change-me-infisical-db-password
# INFISICAL_AUTH_SECRET=change-me-32-char-auth-secret
# INFISICAL_ENCRYPTION_KEY=change-me-32-char-encryption-key
