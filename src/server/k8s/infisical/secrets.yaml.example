# TEMPLATE ONLY — never commit with real values. Apply with kubectl after filling in.
# SECRET_MANAGER_TOKEN is a service/machine identity token from the Infisical
# UI, not a Universal Auth clientId/clientSecret pair — the server sends it
# straight as a Bearer token to Infisical's API (30s TTL cache), the same
# live-fetch code path Docker Compose uses.
apiVersion: v1
kind: Secret
metadata:
  name: mallard-infisical-secrets
  namespace: mallard
stringData:
  SECRET_MANAGER_TOKEN: "CHANGE_ME_INFISICAL_MACHINE_TOKEN"
  INFISICAL_PROJECT_ID: "CHANGE_ME_PROJECT_ID"
