# TEMPLATE ONLY — never commit with real values. Apply with kubectl after filling in.
#
# mallard-server-secrets below carries the server's credentials in the default
# static configuration (SECRET_MANAGER_TYPE=static): a plain Kubernetes Secret
# is a first-class production setup. If you want live rotation without
# restarts, apply k8s/openbao/secrets.yaml.example and its overlay
# (`kubectl apply -k k8s/openbao/`) instead — then API_KEYS here is unused.
apiVersion: v1
kind: Secret
metadata:
  name: influxdb-secrets
  namespace: mallard
stringData:
  DOCKER_INFLUXDB_INIT_USERNAME: "admin"
  DOCKER_INFLUXDB_INIT_PASSWORD: "CHANGE_ME"
  DOCKER_INFLUXDB_INIT_ADMIN_TOKEN: "CHANGE_ME"
  INFLUX_TOKEN: "CHANGE_ME"
---
apiVersion: v1
kind: Secret
metadata:
  name: mallard-server-secrets
  namespace: mallard
stringData:
  # label:key pairs (or bare keys). Read directly by the server in the
  # default static configuration; ignored when the OpenBao overlay is applied.
  API_KEYS: "alice:CHANGE_ME_KEY1,bob:CHANGE_ME_KEY2"
  INFLUX_TOKEN: "CHANGE_ME"
---
apiVersion: v1
kind: Secret
metadata:
  name: grafana-secrets
  namespace: mallard
stringData:
  GF_SECURITY_ADMIN_PASSWORD: "CHANGE_ME"
  # Expanded into the provisioned InfluxDB datasource
  # (grafana/provisioning-configmap.yaml). Grafana only reads — create a
  # READ-ONLY token scoped to the metrics bucket (see src/server/docs/
  # grafana-token.md), NOT the admin token above: a Grafana compromise must
  # not yield write/delete access to the metrics store.
  INFLUX_TOKEN: "CHANGE_ME_READ_ONLY_TOKEN"
