# TEMPLATE ONLY — never commit with real values. Apply with kubectl after filling in.
#
# mallard-server-secrets below is dev/test-only: API_KEYS here is not read by
# the running server (it always requires a live secret manager — see
# Settings.secret_manager_type in src/server/config.py) and would only matter
# if you were constructing a StaticCredentialVerifier directly, which
# production config can't select. A real deployment also needs one of
# k8s/infisical/secrets.yaml.example or k8s/openbao/secrets.yaml.example
# applied alongside this file, plus its matching overlay
# (`kubectl apply -k k8s/infisical/` or `kubectl apply -k k8s/openbao/`).
apiVersion: v1
kind: Secret
metadata:
  name: influxdb-secrets
  namespace: mallard
stringData:
  DOCKER_INFLUXDB_INIT_USERNAME: "admin"
  DOCKER_INFLUXDB_INIT_PASSWORD: "CHANGE_ME"
  DOCKER_INFLUXDB_INIT_ADMIN_TOKEN: "CHANGE_ME"
  INFLUX_TOKEN: "CHANGE_ME"
---
apiVersion: v1
kind: Secret
metadata:
  name: mallard-server-secrets
  namespace: mallard
stringData:
  # Dev/test-only — see the note above. Real credentials live in whichever
  # secret manager's own Secret you apply (mallard-infisical-secrets or
  # mallard-openbao-secrets).
  API_KEYS: "CHANGE_ME_KEY1,CHANGE_ME_KEY2"
  INFLUX_TOKEN: "CHANGE_ME"
---
apiVersion: v1
kind: Secret
metadata:
  name: grafana-secrets
  namespace: mallard
stringData:
  GF_SECURITY_ADMIN_PASSWORD: "CHANGE_ME"
