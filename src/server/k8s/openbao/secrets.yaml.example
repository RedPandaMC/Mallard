# TEMPLATE ONLY — never commit with real values. Apply with kubectl after filling in.
# SECRET_MANAGER_TOKEN here is the OpenBao client token from approle-setup.sh's
# login step. The server polls OpenBao directly with this token (30s TTL
# cache) — the same live-fetch code path Docker Compose uses, just pointed at
# an in-cluster OpenBao instead of a container on the same network.
apiVersion: v1
kind: Secret
metadata:
  name: mallard-openbao-secrets
  namespace: mallard
stringData:
  SECRET_MANAGER_TOKEN: "CHANGE_ME_OPENBAO_CLIENT_TOKEN"
