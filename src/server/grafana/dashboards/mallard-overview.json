{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "influxdb", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "mallard-influx" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "query": "from(bucket: \"metrics\")\n  |> range(start: -7d)\n  |> filter(fn: (r) => r._measurement == \"mallard_metrics\" and r._field == \"today_credits\")\n  |> aggregateWindow(every: 1h, fn: mean)\n  |> yield(name: \"credits\")",
          "refId": "A"
        }
      ],
      "title": "Credits per hour (all instances)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "influxdb", "uid": "mallard-influx" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 1.0 }
            ]
          },
          "max": 1,
          "min": 0,
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "query": "from(bucket: \"metrics\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"mallard_metrics\" and r._field == \"mtd_budget_pct\")\n  |> last()\n  |> yield(name: \"budget_pct\")",
          "refId": "A"
        }
      ],
      "title": "MTD Budget %",
      "type": "gauge"
    },
    {
      "datasource": { "type": "influxdb", "uid": "mallard-influx" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["uniqueValues"] } },
      "targets": [
        {
          "query": "from(bucket: \"metrics\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"mallard_metrics\")\n  |> keep(columns: [\"instance_id\"])\n  |> distinct(column: \"instance_id\")\n  |> count()\n  |> yield(name: \"active_instances\")",
          "refId": "A"
        }
      ],
      "title": "Active Instances (24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "influxdb", "uid": "mallard-influx" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisPlacement": "auto" }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "options": { "barRadius": 0.1, "groupWidth": 0.7, "orientation": "horizontal" },
      "targets": [
        {
          "query": "from(bucket: \"metrics\")\n  |> range(start: -7d)\n  |> filter(fn: (r) => r._measurement == \"mallard_metrics\" and r._field == \"today_credits\")\n  |> group(columns: [\"instance_id\"])\n  |> sum()\n  |> sort(columns: [\"_value\"], desc: true)\n  |> limit(n: 10)\n  |> yield(name: \"top_instances\")",
          "refId": "A"
        }
      ],
      "title": "Top 10 Instances by Credits (7d)",
      "type": "barchart"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["mallard"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Mallard Overview",
  "uid": "mallard-overview",
  "version": 1
}
