{
  "name": "weevil",
  "displayName": "Weevil",
  "description": "Real-time Copilot cost and credit tracker. Parses local OTel logs to show exactly what you're spending.",
  "version": "0.2.0",
  "publisher": "jurreandenys",
  "license": "MIT",
  "author": {
    "name": "Jurrean De Nys"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RedPandaMC/weevil.git"
  },
  "bugs": {
    "url": "https://github.com/RedPandaMC/weevil/issues"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Visualization",
    "AI",
    "Other"
  ],
  "keywords": [
    "copilot",
    "usage",
    "tokens",
    "credits",
    "cost",
    "forecasting",
    "dashboard"
  ],
  "icon": "media/weevil-icon.png",
  "galleryBanner": {
    "color": "#1B1B1F",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "weevil",
          "title": "Weevil",
          "icon": "media/weevil-activitybar.svg"
        }
      ]
    },
    "views": {
      "weevil": [
        {
          "type": "webview",
          "id": "weevil.sidebar",
          "name": "Usage"
        }
      ]
    },
    "commands": [
      {
        "command": "weevil.openDashboard",
        "title": "Open Dashboard",
        "category": "Weevil",
        "icon": "$(graph)"
      },
      {
        "command": "weevil.refresh",
        "title": "Refresh Now",
        "category": "Weevil",
        "icon": "$(refresh)"
      },
      {
        "command": "weevil.clearData",
        "title": "Clear All Data",
        "category": "Weevil"
      },
      {
        "command": "weevil.showLogPath",
        "title": "Show Detected Log Path",
        "category": "Weevil"
      },
      {
        "command": "weevil.signIn",
        "title": "Sign In to GitHub",
        "category": "Weevil",
        "icon": "$(account)"
      },
      {
        "command": "weevil.exportReport",
        "title": "Export Monthly Report",
        "category": "Weevil",
        "icon": "$(export)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "weevil.refresh",
          "when": "view == weevil.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "weevil.openDashboard",
          "when": "view == weevil.sidebar",
          "group": "navigation@2"
        }
      ],
      "commandPalette": []
    },
    "configuration": {
      "title": "Weevil",
      "properties": {
        "weevil.copilotLogPath": {
          "type": "string",
          "default": "",
          "description": "Override path to the Copilot log directory (blank = auto-detect via VS Code logUri)."
        },
        "weevil.pricingManifestUrl": {
          "type": "string",
          "default": "",
          "description": "Override URL for the pricing manifest JSON. Leave blank to use the auto-refreshed default."
        }
      }
    }
  },
  "scripts": {
    "compile": "bun esbuild.mjs",
    "watch": "bun esbuild.mjs --watch",
    "package": "bun esbuild.mjs --production",
    "check-types": "tsc -p tsconfig.host.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "lint": "eslint src webview test",
    "test:unit": "mocha",
    "compile-tests": "tsc -p tsconfig.host.json --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run check-types && bun run lint",
    "test": "vscode-test",
    "vscode:prepublish": "bun run package",
    "vsce:package": "vsce package",
    "docs:build": "vitepress build docs"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.3-r.3",
    "chalk": "2.4.2",
    "echarts": "^5.5.1",
    "neverthrow": "^8.2.0",
    "p-retry": "^8.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@preact/signals-core": "^1.14.2",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.95.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.23.0",
    "eslint": "^9.9.0",
    "mocha": "^10.7.0",
    "prettier": "^3.3.3",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "vitepress": "^1.6.4",
    "zustand": "^5.0.14"
  }
}
