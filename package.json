{
  "name": "weevil",
  "displayName": "Weevil",
  "description": "Real-time Copilot cost and credit tracker — parses local OTel logs to show exactly what you're spending.",
  "version": "0.2.0",
  "publisher": "jurreandenys",
  "license": "MIT",
  "author": {
    "name": "Jurrean De Nys"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RedPandaMC/weevil.git"
  },
  "bugs": {
    "url": "https://github.com/RedPandaMC/weevil/issues"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Visualization",
    "AI",
    "Other"
  ],
  "keywords": [
    "copilot",
    "usage",
    "tokens",
    "credits",
    "cost",
    "forecasting",
    "dashboard"
  ],
  "icon": "media/weevil-icon.svg",
  "galleryBanner": {
    "color": "#1B1B1F",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "weevil",
          "title": "Weevil",
          "icon": "media/weevil-activitybar.svg"
        }
      ]
    },
    "views": {
      "weevil": [
        {
          "type": "webview",
          "id": "weevil.sidebar",
          "name": "Usage"
        }
      ]
    },
    "commands": [
      {
        "command": "weevil.openDashboard",
        "title": "Open Dashboard",
        "category": "Weevil",
        "icon": "$(graph)"
      },
      {
        "command": "weevil.refresh",
        "title": "Refresh Now",
        "category": "Weevil",
        "icon": "$(refresh)"
      },
      {
        "command": "weevil.clearData",
        "title": "Clear All Data",
        "category": "Weevil"
      },
      {
        "command": "weevil.showLogPath",
        "title": "Show Detected Log Path",
        "category": "Weevil"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "weevil.refresh",
          "when": "view == weevil.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "weevil.openDashboard",
          "when": "view == weevil.sidebar",
          "group": "navigation@2"
        }
      ],
      "commandPalette": []
    },
    "configuration": {
      "title": "Weevil",
      "properties": {
        "weevil.copilotLogPath": {
          "type": "string",
          "default": "",
          "description": "Override path to the Copilot log directory (blank = auto-detect via VS Code logUri)."
        },
        "weevil.includedCredits": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "description": "Monthly included premium requests for your Copilot plan. Used to colour the spend gauge."
        },
        "weevil.monthlyBudget": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Monthly USD spend alert threshold. Weevil notifies you at 80% and 100%. Set to 0 to disable."
        },
        "weevil.alert.dailyCredits": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Alert when daily credit usage exceeds this value. Set to 0 to disable."
        },
        "weevil.pricingManifestUrl": {
          "type": "string",
          "default": "",
          "description": "Override URL for the pricing manifest JSON. Leave blank to use the auto-refreshed default."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production",
    "check-types": "tsc -p tsconfig.host.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "lint": "eslint src webview test",
    "test:unit": "mocha",
    "compile-tests": "tsc -p tsconfig.host.json --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run check-types && npm run lint",
    "test": "vscode-test",
    "vscode:prepublish": "npm run package",
    "vsce:package": "vsce package"
  },
  "dependencies": {
    "echarts": "^5.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.95.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.23.0",
    "eslint": "^9.9.0",
    "mocha": "^10.7.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "vitepress": "^1.6.4"
  }
}
