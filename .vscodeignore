node_modules/**
# DuckDB native binding ships inside the VSIX. Run scripts/prune-duckdb.mjs
# <target> before `vsce package --target <target>` so exactly ONE platform
# binding remains under @duckdb — otherwise every installed platform's
# ~35-70 MB binding is bundled, and platforms without an installed binding
# get a broken build.
!node_modules/@duckdb/**
**/*.ts
**/*.map
.gitignore
.prettierrc.json
.mocharc.json
eslint.config.mjs
esbuild.mjs
tsconfig*.json
**/.DS_Store
